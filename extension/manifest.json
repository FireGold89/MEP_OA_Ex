{
  "manifest_version": 3,
  "name": "採購立項自動化工具",
  "version": "4.12.3",
  "description": "自動填寫泛微 OA 採購立項流程表單",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "world": "ISOLATED"
    },
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "main_bridge.js"
      ],
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}